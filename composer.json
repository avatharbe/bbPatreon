{
    "name": "avathar/bbpatreon",
    "type": "phpbb-extension",
    "description": "Patreon integration: OAuth account linking, tier-based group sync, webhooks, and cron reconciliation.",
    "homepage": "https://github.com/avatharbe/bbPatreon",
    "version": "1.0.0",
    "time": "2026-04-10",
    "license": "GPL-2.0-only",
    "authors": [
        {
            "name": "Andy Vandenberghe",
            "email": "sajaki@avathar.be",
            "homepage": "https://www.avathar.be/forum",
            "role": "developer"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "composer/installers": "~1.0"
    },
    "extra": {
        "display-name": "bbPatreon",
        "soft-require": {
            "phpbb/phpbb": ">=3.3.0,<4.0.0@dev"
        },
        "version-check": {
            "host": "www.avathar.be",
            "directory": "/versioncheck",
            "filename": "bbpatreon.json"
        }
    }
}
